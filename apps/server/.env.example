# ==========================================
# 🌐 SERVER CONFIGURATION
# ==========================================
# The port your Node.js server will run on
PORT=3000
NODE_ENV=development

# ==========================================
# 🗄️ DATABASE CONFIGURATION
# ==========================================
# Redis Connection (Local docker-compose default shown)
REDIS_URL=redis://localhost:6379

# ==========================================
# 🔒 SECURITY
# ==========================================
# Bouncer Key: Must match EXPO_PUBLIC_APP_SECRET in the mobile app
MOBILE_APP_SECRET=your_super_secret_development_key

# Web Security (CORS): Comma-separated domains allowed to connect via browser
ALLOWED_ORIGINS=http://localhost:8081,https://stop-the-bus-web.vercel.app

# ==========================================
# 📂 DATA PIPELINE & SEEDING
# ==========================================
# Path to the source CSV file containing valid words
WORDS_CSV_PATH=./data/words.csv

# Output path for the built SQLite database (used by the mobile app)
SQLITE_DB_PATH=./data/game.db