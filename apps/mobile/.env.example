# ==========================================
# 🌐 NETWORK CONFIGURATION
# ==========================================
# Change this URL depending on how you are running your mobile app:
# - iOS Simulator: http://localhost:3000
# - Android Emulator: http://10.0.2.2:3000
# - Physical Device (via Expo Go): http://YOUR_WIFI_IP_ADDRESS:3000
EXPO_PUBLIC_SERVER_URL=http://localhost:3000

# ==========================================
# 🔒 SECURITY
# ==========================================
# Handshake Token: Must match MOBILE_APP_SECRET on the server to pass the connection bouncer
EXPO_PUBLIC_APP_SECRET=your_super_secret_development_key