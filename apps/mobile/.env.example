# The URL of your Node.js backend.
# Must be set — the app will show an error screen and refuse to start without it.
#
# Find your machine's local IP:  ifconfig | grep "inet " (macOS/Linux)
#                                 ipconfig (Windows)
#
# Physical device / Expo Go:  use your machine's LAN IP
# Android Emulator:           use 10.0.2.2
# iOS Simulator:              use your machine's LAN IP or 127.0.0.1
#
EXPO_PUBLIC_SERVER_URL=http://192.168.x.x:3000