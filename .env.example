# Server Configuration
PORT=3000
NODE_ENV=development

# Redis Configuration
# For local dev with Docker, use redis://localhost:6379
REDIS_URL=redis://localhost:6379

# CORS Configuration
# Comma-separated list of origins, e.g., http://localhost:8080,https://mygame.com
# For dev, you can leave unset or use *
ALLOWED_ORIGINS=*

# SQLite & Data Configuration (Optional Absolute Paths for Production)
# SQLITE_DB_PATH=/app/data/game.db
# WORDS_CSV_PATH=/app/data/words.csv